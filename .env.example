# Training Hub — environment variable reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env before running the deployment.
# .env is gitignored and will be overwritten by infra/deploy.sh with real values.
# NEVER commit .env or any file containing real keys or tokens.
#
# Fresh-deployment checklist:
#   1. az login --tenant <new-tenant-id>
#   2. ./infra/deploy.sh [resource-group] [location]   ← populates .env automatically
#   3. Run: az ad app create --display-name "Training Hub" \
#              --sign-in-audience AzureADandPersonalMicrosoftAccount \
#              --web-redirect-uris "$AZURE_SWA_URL/.auth/login/aad/callback"
#      Then: az ad app credential reset --id <appId> --years 2 --append
#      Save appId → AAD_CLIENT_ID, password → AAD_CLIENT_SECRET, tenantId → AAD_TENANT_ID
#   4. az staticwebapp appsettings set --name $AZURE_SWA_NAME \
#        --setting-names AAD_CLIENT_ID=$AAD_CLIENT_ID AAD_CLIENT_SECRET=$AAD_CLIENT_SECRET
#   5. Add AZURE_STATIC_WEB_APPS_API_TOKEN secret to GitHub repo (= $AZURE_SWA_DEPLOYMENT_TOKEN)
# ─────────────────────────────────────────────────────────────────────────────

# ── Resource Group ────────────────────────────────────────────────────────────
# The Azure resource group that contains all Training Hub resources.
AZURE_RESOURCE_GROUP=rg-training-hub

# ── Azure Static Web Apps ─────────────────────────────────────────────────────
# Resource name — set by Bicep as: traininghub-<uniqueString(resourceGroup().id)>
# SKU: Standard ($9/month) — required for auth config in staticwebapp.config.json
AZURE_SWA_NAME=traininghub-<unique-suffix>

# Public URL of the deployed site (no trailing slash).
AZURE_SWA_URL=https://<random>.azurestaticapps.net

# Deployment token — used by the SWA CLI (deploy.sh) and GitHub Actions.
# Add this value as the GitHub repository secret: AZURE_STATIC_WEB_APPS_API_TOKEN
AZURE_SWA_DEPLOYMENT_TOKEN=<deployment-token-from-bicep-output>

# ── Blob Storage — media assets ───────────────────────────────────────────────
# Storage account name — set by Bicep as: traininghubmedia-<uniqueString(resourceGroup().id)>
# Three private containers are created automatically: diagrams / videos / questionbanks
AZURE_MEDIA_STORAGE_ACCOUNT=traininghubmedia<unique-suffix>

# Primary storage account key — fetched by deploy.sh via az storage account keys list.
# Used by the generator (generate.py) to upload diagram PNGs and mint SAS tokens.
AZURE_MEDIA_STORAGE_KEY=<storage-account-key>

# ── AAD App Registration ──────────────────────────────────────────────────────
# These are stored here for reference / re-deployment.
# AAD_CLIENT_ID and AAD_CLIENT_SECRET are ALSO pushed to SWA app settings via:
#   az staticwebapp appsettings set --name $AZURE_SWA_NAME \
#     --setting-names AAD_CLIENT_ID=$AAD_CLIENT_ID AAD_CLIENT_SECRET=$AAD_CLIENT_SECRET
# The SWA runtime reads them from app settings — NOT from this file.
#
# App registration:
#   Name:                   Training Hub
#   Supported account types: Accounts in any org directory AND personal Microsoft accounts
#   Redirect URI (Web):     $AZURE_SWA_URL/.auth/login/aad/callback
#   OpenID issuer:          https://login.microsoftonline.com/common/v2.0
AAD_CLIENT_ID=CHANGE_ME_app-registration-client-id
AAD_CLIENT_SECRET=CHANGE_ME_client-secret-value
AAD_TENANT_ID=CHANGE_ME_tenant-id
